      "example": "themes/playful/example.html",
      "preview": "themes/playful/screenshots/example-overview-1280x720.png",
      "extras": [],
      "verify": {
        "required_tokens": [
          "--bg",
          "--ink",
          "--accent",
          "--accent-2",
          "--accent-3",
          "--accent-4",
          "--font-display",
          "--font-body"
        ],
        "accent_rgb": "255, 107, 107",
        "accent_max_per_slide": 8,
        "logo_pattern": null,
        "require_logo_on_content_slides": false,
        "forbid_chart_on_gradient": false,
        "headline_contrast_min": 4.5,
        "palette_lock": true
      }
    }
  ]
}
