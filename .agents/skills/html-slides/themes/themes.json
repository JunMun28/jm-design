{
  "$schema": "./themes.schema.json",
  "version": 2,
  "shared": {
    "logos": {
      "white": "themes/_shared/micron-logo-white-tm-rgb.png",
      "black": "themes/_shared/micron-logo-black-tm-rgb.png"
    },
    "fonts": {
      "micron-basis": "themes/_shared/fonts/micron-basis.woff2"
    }
  },
  "themes": [
    {
      "id": "micron-dark-executive",
      "name": "Micron dark executive",
      "status": "stable",
      "role": "executive-cover",
      "when": "Premium Micron executive style with cinematic dark surfaces, restrained chrome, and polished pacing.",
      "design": "themes/micron-dark-executive/design.md",
      "example": "themes/micron-dark-executive/example.html",
      "preview": "themes/micron-dark-executive/screenshots/example-overview-1280x720.png",
      "extras": [
        "themes/micron-dark-executive/title-templates.md"
      ],
      "verify": {
        "required_tokens": [
          "--micron-black",
          "--micron-white",
          "--micron-accent",
          "--font-display",
          "--scale-ratio",
          "--col-count"
        ],
        "accent_rgb": "189, 3, 247",
        "accent_max_per_slide": 4,
        "logo_pattern": "micron-logo",
        "require_logo_on_content_slides": true,
        "forbid_chart_on_gradient": true,
        "headline_contrast_min": 4.5,
        "palette_lock": true,
        "premium_corporate_checks": true,
        "require_logo_image": true,
        "title_image_pattern": "micron-dark-title-image|title-image",
        "title_logo_pattern": "micron-logo-white",
        "forbid_accent_text_selectors": [
          "h1",
          "h2",
          "h3",
          ".kicker",
          ".eyebrow",
          ".label",
          ".chart-label",
          "th"
        ],
        "enforce_sentence_case_headlines": true,
        "forbid_headline_end_punctuation": true,
        "min_label_body_gap_px": 10
      }
    },
    {
      "id": "micron-dark",
      "name": "Micron dark",
      "status": "stable",
      "role": "engineering-review",
      "recommended": true,
      "when": "Dark technical interface with dense layouts, sharp grids, Micron purple accents, and strong data surfaces.",
      "design": "themes/micron-dark/design.md",
      "example": "themes/micron-dark/example.html",
      "preview": "themes/micron-dark/screenshots/example-overview-1280x720.png",
      "extras": [
        "themes/micron-dark/title-templates.md"
      ],
      "verify": {
        "required_tokens": [
          "--micron-black",
          "--micron-white",
          "--micron-accent",
          "--font-display",
          "--scale-ratio",
          "--col-count"
        ],
        "accent_rgb": "189, 3, 247",
        "accent_max_per_slide": 4,
        "forbid_visible_accent_rgb": "50, 200, 255",
        "forbid_visible_accent_name": "cyan",
        "forbid_selectors": [
          ".title-slide .md-title-number"
        ],
        "logo_pattern": "micron-logo",
        "require_logo_on_content_slides": true,
        "forbid_chart_on_gradient": true,
        "headline_contrast_min": 4.5,
        "palette_lock": true,
        "require_fixed_stage": true,
        "stage_width": 1600,
        "stage_height": 900,
        "enforce_stage_overflow": true,
        "require_title_animated_icon": true,
        "title_icon_pattern": "assets/primary/mp4/rev/.+\\.mp4",
        "title_visual_selector": ".title-wafer .md-wafer-canvas",
        "require_title_template_selector": ".title-slide.title-wafer .md-wafer-canvas",
        "require_title_shader_ready": true
      }
    },
    {
      "id": "micron-light",
      "name": "Micron light",
      "status": "stable",
      "role": "editorial-data",
      "when": "Bright editorial system with clean white panels, crisp tables, quiet grid lines, and print-ready spacing.",
      "design": "themes/micron-light/design.md",
      "example": "themes/micron-light/example.html",
      "preview": "themes/micron-light/screenshots/example-overview-1280x720.png",
      "extras": [],
      "verify": {
        "required_tokens": [
          "--micron-black",
          "--micron-white",
          "--micron-accent",
          "--font-display",
          "--scale-ratio",
          "--col-count"
        ],
        "accent_rgb": "189, 3, 247",
        "accent_max_per_slide": 24,
        "logo_pattern": "micron-logo",
        "require_logo_on_content_slides": true,
        "forbid_chart_on_gradient": true,
        "headline_contrast_min": 4.5,
        "palette_lock": true,
        "forbid_selectors": [
          ".slide-coord"
        ],
        "require_title_mesh_background": true,
        "micron_light_title_checks": true,
        "title_icon_pattern": "(micron-icons/.+primary/mp4/pos/.+\\.mp4|assets/primary/mp4/pos/.+\\.mp4)",
        "title_icon_fallback_pattern": "(micron-icons/.+primary/png/pos/.+\\.png|assets/primary/png/pos/.+\\.png)",
        "min_title_copy_gap_px": 24,
        "min_title_icon_width_px": 300,
        "min_title_icon_right_margin_px": 72
      }
    },
    {
      "id": "guided-learning",
      "name": "Guided learning",
      "status": "stable",
      "role": "training",
      "when": "Polished guided-learning modules with lavender-gray app-shell surfaces, soft rounded panels, restrained graphite type, and Micron-purple session accents.",
      "design": "themes/guided-learning/design.md",
      "example": "themes/guided-learning/example.html",
      "preview": "themes/guided-learning/screenshots/example-overview-1280x720.png",
      "extras": [],
      "verify": {
        "required_tokens": [
          "--bg",
          "--surface",
          "--text-1",
          "--text-2",
          "--accent",
          "--font-display"
        ],
        "accent_rgb": "189, 3, 247",
        "accent_max_per_slide": 10,
        "logo_pattern": null,
        "require_logo_on_content_slides": false,
        "forbid_chart_on_gradient": true,
        "headline_contrast_min": 4.5,
        "palette_lock": true,
        "require_fixed_stage": true,
        "stage_width": 1280,
        "stage_height": 720,
        "enforce_stage_overflow": true,
        "min_touch_target_px": 44
      }
    },
    {
      "id": "playful",
