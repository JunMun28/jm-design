{
  "name": "@slide-studio/daemon",
  "version": "0.1.0",
  "private": true,
  "description": "Slide Studio local daemon: detects + drives the agent CLI (codex/Copilot), normalizes its JSON event stream, and streams over WebSocket to the Angular + Atlas shell.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "slide-studio": "./bin/slide-studio.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node bin/slide-studio.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types",
    "sync:skills": "node ../../scripts/sync-skills.mjs"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "express": "^5.1.0",
    "open": "^10.1.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.2"
  }
}
